rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // Custom Claims-based role checks (no get() = no extra reads = lower cost)
    function isAdmin() {
      return signedIn() && request.auth.token.role == 'admin';
    }


    function isStaff() {
      return signedIn() && request.auth.token.role in ['admin', 'moderator'];
    }


    match /users/{userId} {
      allow read: if true;

      allow create: if isOwner(userId)
        && request.resource.data.role == 'user';

      // Users cannot modify their own role, points, badges, or xp
      allow update: if (
        isOwner(userId)
        && request.resource.data.role == resource.data.role
        && request.resource.data.points == resource.data.points
        && request.resource.data.badges == resource.data.badges
        && request.resource.data.xp == resource.data.xp
      ) || isStaff();

      allow delete: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /lineups/{lineupId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if (
        signedIn()
        && resource.data.userId == request.auth.uid
      ) || isStaff();

      match /likes/{userId} {
        allow read: if true;
        allow create: if signedIn()
          && request.auth.uid == userId;
        allow update, delete: if isStaff();
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if signedIn()
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isStaff();
      }
    }

    match /posts/{postId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if (
        signedIn()
        && resource.data.userId == request.auth.uid
      ) || isStaff();

      match /comments/{commentId} {
        allow read: if true;

        allow create: if signedIn()
          && request.resource.data.userId == request.auth.uid;

        allow update, delete: if (
          signedIn()
          && resource.data.userId == request.auth.uid
        ) || isStaff();
      }
    }

    match /predictions/{predictionId} {
      allow read: if (
        signedIn()
        && resource.data.userId == request.auth.uid
      ) || isStaff();

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    match /chatRooms/{roomId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isStaff()
        || (
          signedIn()
          && resource.data.createdBy == request.auth.uid
        );

      match /messages/{messageId} {
        allow read: if true;

        allow create: if signedIn()
          && request.resource.data.userId == request.auth.uid;

        allow update, delete: if (
          signedIn()
          && resource.data.userId == request.auth.uid
        ) || isStaff();
      }
    }

    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid;

      allow read: if (
        signedIn()
        && resource.data.reporterId == request.auth.uid
      ) || isStaff();

      allow update, delete: if isStaff();
    }

    match /errorReports/{reportId} {
      allow create: if signedIn();
      allow read, update, delete: if isStaff();
    }

    match /auditLogs/{logId} {
      allow read, create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow create: if signedIn();
      allow read, update, delete: if isStaff();
    }

    match /appSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if (
        signedIn()
        && resource.data.userId == request.auth.uid
      ) || isAdmin();

      allow create: if signedIn();

      allow update: if (
        signedIn()
        && resource.data.userId == request.auth.uid
      ) || isAdmin();

      allow delete: if isAdmin();
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Users can only update answers/respondents (voting), not the question itself
      allow update: if signedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['answers', 'respondents']);
    }
  }
}
